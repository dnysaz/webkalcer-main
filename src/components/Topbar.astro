---
const { activeNav = 'home' } = Astro.props;
const isHome = activeNav === 'home';
const p = (href) => isHome ? href : `/${href}`;
---

<header style="position:fixed;top:0;left:0;right:0;z-index:90;padding:18px 28px;display:flex;align-items:center;justify-content:space-between;transition:all 0.4s var(--ease);" id="topbar">
    <a href="/" style="font-weight:700;font-size:1.05rem;letter-spacing:-0.02em;"><span class="brand">web</span><span class="brand-a">kalcer</span></a>
    <nav style="display:flex;align-items:center;gap:4px;">
        <a href={p("#layanan")} class="nav-link">Layanan</a>
        <a href={p("#proses")} class="nav-link">Proses</a>
        <a href="/package" class="nav-link" style={activeNav === 'package' ? 'background:var(--bg-3);font-weight:600;color:var(--fg);' : ''}>Paket</a>
        <a href={p("#harga")} class="nav-link">Harga</a>
        <a href={p("#faq")} class="nav-link">FAQ</a>
        <a href={p("#kontak")} class="btn btn-solid" style="margin-left:6px;padding:7px 18px;font-size:0.83rem;">Hubungi</a>
    </nav>
    <div style="display:flex;align-items:center;gap:8px;">
        <button id="theme-toggle" style="width:34px;height:34px;border-radius:8px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--fg-2);transition:all 0.2s;flex-shrink:0;" aria-label="Ganti tema">
            <svg id="theme-icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none;"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg id="theme-icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </button>
        <button id="menu-open" style="display:none;font-size:1.25rem;padding:8px;" aria-label="Buka menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.5 5h15M2.5 10h15M2.5 15h15"/></svg>
        </button>
    </div>
</header>

<!-- MOBILE MENU -->
<div id="mobile-menu" style="position:fixed;inset:0;z-index:200;background:var(--bg);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:32px;opacity:0;pointer-events:none;transition:opacity 0.4s var(--ease);">
    <button id="menu-close" style="position:absolute;top:24px;right:28px;font-size:1.25rem;padding:8px;" aria-label="Tutup menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 5l10 10M15 5l-10 10"/></svg>
    </button>
    <a href={p("#layanan")} class="mobile-link" style="font-size:1.5rem;font-weight:600;color:var(--fg-2);">Layanan</a>
    <a href={p("#proses")} class="mobile-link" style="font-size:1.5rem;font-weight:600;color:var(--fg-2);">Proses</a>
    <a href="/package" class="mobile-link" style="font-size:1.5rem;font-weight:600;color:{activeNav === 'package' ? 'var(--fg)' : 'var(--fg-2)'};">Paket</a>
    <a href={p("#harga")} class="mobile-link" style="font-size:1.5rem;font-weight:600;color:var(--fg-2);">Harga</a>
    <a href={p("#faq")} class="mobile-link" style="font-size:1.5rem;font-weight:600;color:var(--fg-2);">FAQ</a>
    <a href={p("#kontak")} class="btn btn-solid" style="padding:14px 48px;font-size:1.05rem;margin-top:12px;width:auto;">Hubungi Kami</a>
</div>
