    <script>
        // ─── Load SEO settings now (all DOM including Footer is available) ───
        const seoPage = window.location.pathname === '/package' ? 'package' : 'home';
        window.__loadSeoSettings(seoPage);

        // ─── Theme toggle ───
        const html = document.documentElement;
        const sun = document.getElementById('theme-icon-sun');
        const moon = document.getElementById('theme-icon-moon');
        const savedTheme = localStorage.getItem('theme') || 'dark';
        html.dataset.theme = savedTheme;
        sun.style.display = savedTheme === 'dark' ? 'none' : 'block';
        moon.style.display = savedTheme === 'dark' ? 'block' : 'none';
        document.getElementById('theme-toggle').addEventListener('click', () => {
            const dark = html.dataset.theme === 'dark';
            const next = dark ? 'light' : 'dark';
            html.dataset.theme = next;
            localStorage.setItem('theme', next);
            sun.style.display = dark ? 'block' : 'none';
            moon.style.display = dark ? 'none' : 'block';
        });

        // ─── Scroll topbar ───
        const topbar = document.getElementById('topbar');
        const sentinel = document.createElement('div');
        sentinel.style.cssText = 'position:absolute;top:80px;left:0;width:1px;height:1px;pointer-events:none;';
        document.body.prepend(sentinel);
        new IntersectionObserver(([e]) => topbar.classList.toggle('scrolled', !e.isIntersecting), { threshold: 0 }).observe(sentinel);
        const scrollStyle = document.createElement('style');
        scrollStyle.textContent = '.scrolled{background:rgba(var(--bg-rgb),0.82);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--accent);padding:12px 28px}';
        document.head.appendChild(scrollStyle);

        // ─── Mobile menu ───
        const mm = document.getElementById('mobile-menu');
        document.getElementById('menu-open').addEventListener('click', () => mm.classList.add('open'));
        document.getElementById('menu-close').addEventListener('click', () => mm.classList.remove('open'));
        mm.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', () => mm.classList.remove('open')));

        // ─── Auto-slide for horizontal scroll sections ───
        function initAutoSlide(container) {
            if (!container) return;
            if (container.scrollWidth <= container.clientWidth) return;
            let speed = 0.6;
            let raf = null;
            let paused = false;
            const scroll = () => {
                if (!paused) {
                    container.scrollLeft += speed;
                    if (container.scrollLeft >= container.scrollWidth - container.clientWidth) {
                        container.scrollLeft = 0;
                    }
                }
                raf = requestAnimationFrame(scroll);
            };
            container.addEventListener('touchstart', () => paused = true);
            container.addEventListener('touchend', () => setTimeout(() => paused = false, 1500));
            container.addEventListener('mouseenter', () => paused = true);
            container.addEventListener('mouseleave', () => paused = false);
            raf = requestAnimationFrame(scroll);
        }
        initAutoSlide(document.querySelector('#keunggulan-grid'));

        // ─── Reveal scroll animations ───
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (!e.isIntersecting) return;
                e.target.classList.add('show');
                obs.unobserve(e.target);
                if (e.target.id === 'angka' || e.target.querySelector('.counter')) {
                    e.target.querySelectorAll('.counter').forEach(c => {
                        const target = parseInt(c.dataset.target) || 0;
                        const suffix = c.dataset.suffix || '';
                        if (c.dataset.animating) return;
                        c.dataset.animating = '1';
                        const dur = 1200;
                        const start = performance.now();
                        const update = (now) => {
                            const p = Math.min((now - start) / dur, 1);
                            const eased = 1 - Math.pow(1 - p, 3);
                            c.textContent = Math.round(eased * target) + suffix;
                            if (p < 1) requestAnimationFrame(update);
                            else c.textContent = target + suffix;
                        };
                        requestAnimationFrame(update);
                    });
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });
        document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

        // ─── FAQ accordion ───
        document.querySelectorAll('.faq-q').forEach(btn => {
            btn.addEventListener('click', () => {
                const answer = btn.nextElementSibling;
                const open = answer.classList.contains('open');
                document.querySelectorAll('.faq-a.open, .faq-q.open').forEach(e => e.classList.remove('open'));
                btn.setAttribute('aria-expanded', !open);
                if (!open) {
                    answer.classList.add('open');
                    btn.classList.add('open');
                    answer.style.maxHeight = answer.scrollHeight + 'px';
                }
            });
        });


        // ─── Stack marquee — clone items for seamless loop ───
        const stackTrack = document.querySelector('.stack-track');
        if (stackTrack) {
            stackTrack.querySelectorAll('.stack-item').forEach(el => {
                stackTrack.appendChild(el.cloneNode(true));
            });
            const wrapper = stackTrack.closest('.stack-wrapper');
            if (wrapper) {
                wrapper.addEventListener('touchstart', () => { stackTrack.style.animationPlayState = 'paused'; }, { passive: true });
                wrapper.addEventListener('touchend', () => { setTimeout(() => { stackTrack.style.animationPlayState = ''; }, 1500); }, { passive: true });
            }
        }

        // ─── Smooth scroll for hash links ───
        document.querySelectorAll('a[href^="#"], a[href^="/#"]').forEach(a => {
            a.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                const id = href.startsWith('/#') ? href.replace('/#', '#') : href;
                if (id === '#') return;
                const t = document.querySelector(id);
                if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
            });
        });
    </script>
</body>
