---
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';

const {
  seoPage = 'home',
  activeNav = 'home',
  pageTitle = 'Jasa Pembuatan Website Profesional Indonesia | Webkalcer',
  pageDesc = 'Webkalcer jasa pembuatan website profesional di Indonesia. Landing page, company profile, toko online custom dari nol. Mulai Rp 300.000. Konsultasi gratis.',
  ogTitle,
  ogDesc,
  ogImage = '',
  canonical = 'https://webkalcer.com/',
  ogUrl = 'https://webkalcer.com/',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="id" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title id="page-title">{pageTitle}</title>
    <meta id="meta-desc" name="description" content={pageDesc}>
    <link rel="canonical" href={canonical}>
    <meta id="og-title" property="og:title" content={ogTitle || pageTitle}>
    <meta id="og-image" property="og:image" content={ogImage}>
    <meta id="og-desc" property="og:description" content={ogDesc || pageDesc}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={ogUrl}>
    <link id="favicon" rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='80'>🤙</text></svg>">
    <script is:inline>(function(){var t=localStorage.getItem('theme');if(t)document.documentElement.dataset.theme=t;})();</script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;0,9..40,900;1,9..40,300;1,9..40,500&family=Sora:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.2/src/regular/style.css">
    <style is:global>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
        body {
            font-family: 'DM Sans', system-ui, sans-serif;
            background: var(--bg);
            color: var(--fg);
            overflow-x: hidden;
            line-height: 1.5;
        }
        img { max-width: 100%; display: block; }
        a { text-decoration: none; color: inherit; }
        button { border: none; background: none; cursor: pointer; font: inherit; color: inherit; }
        ul { list-style: none; }
        ::selection { background: var(--accent-dim); color: var(--fg); }

        :root {
            --bg: #fafafa;
            --bg-2: #ffffff;
            --bg-3: #f5f5f5;
            --fg: #0b0b0b;
            --fg-2: #525252;
            --fg-3: #a3a3a3;
            --accent: #d97706;
            --accent-dim: rgba(217, 119, 6, 0.1);
            --accent-glow: rgba(217, 119, 6, 0.04);
            --border: #e5e5e5;
            --radius: 10px;
            --max-w: 1280px;
            --ease: cubic-bezier(0.22, 1, 0.36, 1);
            --bg-rgb: 250, 250, 250;
            --accent-rgb: 217, 119, 6;
        }

        [data-theme="dark"] {
            --bg-rgb: 11, 11, 11;
            --accent-rgb: 245, 158, 11;
            --bg: #0b0b0b;
            --bg-2: #141414;
            --bg-3: #1c1c1c;
            --fg: #f5f5f5;
            --fg-2: #a3a3a3;
            --fg-3: #6b7280;
            --accent: #f59e0b;
            --accent-dim: rgba(245, 158, 11, 0.1);
            --accent-glow: rgba(245, 158, 11, 0.06);
            --border: #1f1f1f;
        }

        .t-display { font-family: 'Sora', system-ui, sans-serif; font-size: clamp(1.8rem, 4.5vw, 2.8rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; }
        .t-h1 { font-family: 'Sora', system-ui, sans-serif; font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; }
        .t-h2 { font-family: 'Sora', system-ui, sans-serif; font-size: clamp(1.3rem, 2.5vw, 1.75rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.2; }
        .t-h3 { font-size: 1.05rem; font-weight: 600; line-height: 1.3; }
        .t-body { font-size: 1rem; line-height: 1.7; color: var(--fg-2); }
        .t-small { font-size: 0.85rem; line-height: 1.6; color: var(--fg-3); }
        .t-mono { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-3); }
        .t-subtitle { font-size: 1.05rem; line-height: 1.6; color: var(--fg-2); }
        .brand { font-weight: 700; letter-spacing: -0.02em; }
        .brand-a { color: var(--accent); font-weight: 800; letter-spacing: -0.02em; }

        .punch {
            font-style: italic;
            text-decoration: underline;
            text-decoration-style: wavy;
            text-decoration-color: var(--accent);
            text-decoration-thickness: 2px;
            text-underline-offset: 4px;
        }

        .container { width: 100%; max-width: var(--max-w); margin: 0 auto; padding: 0 28px; }
        .section { padding: 140px 0; }
        .section-sm { padding: 100px 0; }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

        .accent-line {
            display: block;
            width: 28px;
            height: 2px;
            background: var(--accent);
            margin-bottom: 20px;
            border-radius: 1px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            font-size: 0.9rem;
            font-weight: 600;
            border-radius: 999px;
            transition: all 0.3s var(--ease);
        }
        .btn-solid {
            background: var(--accent);
            color: #fafafa;
        }
        .btn-solid:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(245, 158, 11, 0.2);
        }
        .nav-link {
            padding: 6px 16px;
            font-size: 0.85rem;
            color: var(--fg-2);
            border-radius: 8px;
            transition: all 0.2s;
        }
        .nav-link:hover { background: var(--bg-3); color: var(--fg); }

        .btn-ghost {
            border: 1px solid var(--border);
            color: var(--fg-2);
        }
        .btn-ghost:hover {
            border-color: var(--fg-3);
            color: var(--fg);
            transform: translateY(-2px);
        }

        #mobile-menu.open { opacity: 1 !important; pointer-events: auto !important; }

        .reveal { opacity: 0; transition: all 0.8s var(--ease); }
        .reveal.show { opacity: 1; transform: translate(0,0) scale(1); }
        .reveal-up { transform: translateY(36px); }
        .reveal-left { transform: translateX(-36px); }
        .reveal-right { transform: translateX(36px); }
        .reveal-scale { transform: scale(0.92); }

        .d-1 { transition-delay: 0.08s; }
        .d-2 { transition-delay: 0.16s; }
        .d-3 { transition-delay: 0.24s; }
        .d-4 { transition-delay: 0.32s; }
        .d-5 { transition-delay: 0.42s; }
        .d-6 { transition-delay: 0.52s; }

        .loading {
            text-align: center;
            padding: 60px 0;
            color: var(--fg-3);
        }
        .loading .spinner {
            width: 32px;
            height: 32px;
            border: 2px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .package-card {
            background: var(--bg-2);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 40px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s var(--ease);
        }
        .package-card:hover {
            border-color: var(--accent);
            transform: translateY(-4px);
            box-shadow: 0 12px 48px rgba(245, 158, 11, 0.08);
        }
        .package-card.featured {
            border-color: var(--accent);
            box-shadow: 0 0 0 1px var(--accent), 0 12px 48px rgba(245, 158, 11, 0.1);
        }
        .package-badge {
            position: absolute;
            top: 16px;
            right: -28px;
            background: var(--accent);
            color: #0b0b0b;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            padding: 4px 40px;
            transform: rotate(45deg);
            white-space: nowrap;
        }
        .package-card .price {
            font-size: 3rem;
            font-weight: 900;
            color: var(--accent);
            letter-spacing: -0.03em;
            line-height: 1;
            margin: 16px 0 4px;
        }
        .package-card .price-sub {
            font-size: 0.85rem;
            color: var(--fg-3);
        }
        .package-card ul {
            margin-top: 24px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .package-card ul li {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            color: var(--fg-2);
        }
        .package-card ul li svg {
            flex-shrink: 0;
        }
        .package-card .btn {
            width: 100%;
            justify-content: center;
            margin-top: 28px;
        }

        @media (max-width: 768px) {
            .section { padding: 64px 0; }
            .section-sm { padding: 48px 0; }
            .container { padding: 0 20px; }
            .t-display { font-size: clamp(2rem, 12vw, 2.8rem) !important; }
            .t-h1 { font-size: clamp(1.5rem, 6vw, 2rem) !important; }
            .t-h3 { font-size: 1rem; }
            .btn { width: 100%; justify-content: center; padding: 14px 24px; }
            #topbar { padding: 14px 16px; }
            #topbar > nav { display: none !important; }
            #menu-open { display: block !important; }
            .scrolled { padding: 10px 16px !important; background: rgba(var(--bg-rgb),0.85) !important; border-bottom-color: var(--accent) !important; }
            #hero { min-height: 90dvh; padding-top: 80px; }
            #hero .t-body { font-size: 0.95rem !important; }
            #hero [style*=\"gap:40px\"] { gap: 20px; flex-wrap: wrap; }
            #hero [style*=\"gap:40px\"] > div { flex: 1; min-width: 0; }
            #hero > [aria-hidden] { display: none; }
            #layanan > .container > div { grid-template-columns: 1fr !important; gap: 32px !important; }
            #layanan [style*=\"padding:24px 0\"] { padding: 20px 0 !important; gap: 14px !important; }
            #proses > .container > div:last-child { grid-template-columns: 1fr !important; gap: 16px !important; }
            #proses [style*=\"padding:36px 28px\"] { padding: 28px 24px !important; }
            #keunggulan-grid { display:flex !important; overflow-x:auto !important; gap:16px !important; scroll-snap-type:x mandatory !important; padding-bottom:12px !important; -webkit-overflow-scrolling:touch !important; scrollbar-width:thin !important; }
            #keunggulan-grid > div { flex: 0 0 280px !important; scroll-snap-align:start !important; padding:28px 24px !important; }
            #angka .stats-grid { grid-template-columns: repeat(2,1fr) !important; gap: 12px !important; }
            #angka .stats-grid .counter { font-size: 1.25rem !important; }
            #angka .stats-grid .t-small { font-size: 0.85rem !important; }
            .stack-wrapper { margin-top: 40px !important; }
            .stack-item { flex: 0 0 140px !important; padding: 22px 14px !important; }
            .stack-item-icon { width: 36px; height: 36px; border-radius: 10px; }
            .stack-item-icon svg { width: 18px; height: 18px; }
            .price-new { font-size: 2.75rem !important; }
            .price-old { font-size: 1.5rem !important; }
            #testimoni [style*=\"flex:0 0 400px\"] { flex: 0 0 290px !important; padding: 28px 24px !important; }
            #testimoni [style*=\"margin-bottom:60px\"] { margin-bottom: 36px !important; }
            #faq > .container > div:last-child { grid-template-columns: 1fr !important; gap: 0 !important; }
            #faq .faq-q { font-size: 0.9rem; padding: 16px 0; gap: 12px; }
            #faq .faq-q svg { min-width: 16px; }
            #faq .faq-a p { font-size: 0.85rem; }
            #kontak { min-height: auto; padding: 80px 0; }
            #kontak .t-display { margin-bottom: 16px; }
            footer > .container > div:first-child { grid-template-columns: 1fr 1fr !important; gap: 32px !important; }
            footer > .container > div:first-child > div:first-child { grid-column: 1 / -1; }
            footer [style*=\"justify-content:space-between\"] { flex-direction: column; gap: 12px; text-align: center; }
            .faq-q { gap: 12px; }
            .faq-q svg { flex-shrink: 0; }
            .package-card { padding: 28px 24px; }
            .package-card .price { font-size: 2.5rem; }
        }

        @media (max-width: 480px) {
            .container { padding: 0 16px; }
            #testimoni [style*=\"flex:0 0 400px\"] { flex: 0 0 260px !important; }
            #angka .stats-grid { grid-template-columns: repeat(2,1fr) !important; gap: 8px !important; }
            #hero [style*=\"gap:40px\"] > div { text-align: center; }
            footer > .container > div:first-child { grid-template-columns: 1fr !important; gap: 28px !important; }
            footer > .container > div:first-child > div:first-child { text-align: center; }
            footer > .container > div:first-child > div:first-child p { max-width: 100% !important; }
            footer > .container > div:first-child > div:first-child > div { justify-content: center; }
        }

        .stack-wrapper {
            overflow: hidden;
            position: relative;
            width: 100%;
            max-width: 100vw;
            padding: 4px 0;
            margin-top: 80px;
        }
        @keyframes scrollStack {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .stack-track {
            display: flex;
            gap: 16px;
            width: max-content;
            animation: scrollStack 60s linear infinite;
            will-change: transform;
        }
        .stack-track:hover {
            animation-play-state: paused;
        }
        .stack-item {
            flex: 0 0 180px;
            background: rgba(var(--bg-rgb), 0.55);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 28px 18px;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.35s var(--ease);
        }
        .stack-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--brand, var(--accent));
            opacity: 0;
            transition: opacity 0.35s var(--ease);
        }
        .stack-item:hover {
            border-color: var(--brand, var(--accent));
            transform: translateY(-6px);
            box-shadow: 0 16px 48px var(--glow, rgba(245,158,11,0.08));
        }
        .stack-item:hover::before {
            opacity: 1;
        }
        .stack-item-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
            transition: transform 0.35s var(--ease);
        }
        .stack-item:hover .stack-item-icon {
            transform: scale(1.12) rotate(-3deg);
        }
        .stack-item-name {
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--fg);
            margin-bottom: 4px;
        }
        .stack-item-desc {
            font-size: 0.78rem;
            color: var(--fg-3);
            line-height: 1.5;
        }

        @media (prefers-reduced-motion: reduce) {
            .stack-track { animation: none; }
        }

        .error-state {
            text-align: center;
            padding: 60px 0;
            color: var(--fg-3);
        }
        .error-state svg { margin-bottom: 16px; }

        .package-grid {
            display: grid;
            gap: 24px;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        }
        .package-grid.grid-1 { grid-template-columns: minmax(auto, 480px); justify-content: center; }
        .package-grid.grid-2 { grid-template-columns: repeat(2, 1fr); }
        .package-grid.grid-3 { grid-template-columns: repeat(3, 1fr); }
        .package-grid.grid-4 { grid-template-columns: repeat(2, 1fr); }

        @media (max-width: 768px) {
            .package-grid,
            .package-grid.grid-2,
            .package-grid.grid-3,
            .package-grid.grid-4 { grid-template-columns: 1fr; }
        }

        /* Floating buttons — mobile only */
        .float-group {
            display: none;
            position: fixed;
            bottom: 24px;
            z-index: 999;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }
        .float-group-left {
            left: 20px;
        }
        .float-group-right {
            right: 20px;
        }
        .float-btn {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s var(--ease);
            -webkit-tap-highlight-color: transparent;
        }
        .float-btn:hover { transform: scale(1.1); }
        .float-btn:active { transform: scale(0.95); }
        .float-btn svg { width: 26px; height: 26px; }
        .float-label {
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.03em;
            color: var(--fg-2);
            white-space: nowrap;
        }

        .wa-floating {
            background: #25D366;
            color: #fff;
            box-shadow: 0 4px 20px rgba(37, 211, 102, 0.3);
        }
        .wa-floating:hover {
            box-shadow: 0 8px 32px rgba(37, 211, 102, 0.5);
        }
        @keyframes waPulse {
            0%, 100% { box-shadow: 0 4px 20px rgba(37, 211, 102, 0.3); }
            50% { box-shadow: 0 4px 28px rgba(37, 211, 102, 0.55); }
        }

        .pkg-floating {
            background: var(--accent);
            color: #fafafa;
            box-shadow: 0 4px 20px rgba(var(--accent-rgb), 0.3);
        }
        .pkg-floating:hover {
            box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.5);
        }
        @keyframes pkgPulse {
            0%, 100% { box-shadow: 0 4px 20px var(--accent-glow); }
            50% { box-shadow: 0 4px 28px var(--accent-dim); }
        }

        @media (max-width: 768px) {
            .float-group {
                display: flex;
            }
            .wa-floating {
                animation: waPulse 2s ease-in-out infinite;
            }
            .pkg-floating {
                animation: pkgPulse 2s ease-in-out infinite;
            }
        }

    </style>
</head>
<body>
    <Topbar activeNav={activeNav} />

    <!-- Shared utilities exposed on window.__ for page scripts in slot -->
    <script>
        window.__SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
        window.__SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

        window.__escapeHtml = function(str) {
            if (!str) return "";
            const div = document.createElement("div");
            div.textContent = str;
            return div.innerHTML;
        };

        window.__formatPrice = function(price) {
            if (price == null) return "";
            const num = typeof price === "string" ? parseInt(price.replace(/[^0-9]/g, "")) : price;
            if (isNaN(num)) return price;
            if (num >= 1000000) return `Rp ${(num / 1000000).toFixed(1).replace(".", ",")}jt`;
            if (num >= 1000) return `Rp ${(num / 1000).toFixed(0)}K`;
            return `Rp ${num.toLocaleString("id-ID")}`;
        };

        window.__loadSeoSettings = async function(page) {
            try {
                const res = await fetch(`${window.__SUPABASE_URL}/rest/v1/seo_settings?page=eq.${page}&select=*`, {
                    headers: { apikey: window.__SUPABASE_KEY, Authorization: `Bearer ${window.__SUPABASE_KEY}` }
                });
                if (!res.ok) return;
                const data = await res.json();
                if (!data || data.length === 0) return;
                const s = data[0];

                function setText(id, val) {
                    const el = document.getElementById(id);
                    if (el && val) el.textContent = val;
                }
                function setContent(id, val) {
                    const el = document.getElementById(id);
                    if (el && val) el.setAttribute('content', val);
                }
                function setHref(id, val) {
                    const el = document.getElementById(id);
                    if (el && val) el.href = val;
                }

                setText('page-title', s.title || '');
                setContent('meta-desc', s.description || '');
                setContent('og-title', s.og_title || s.title || '');
                setContent('og-desc', s.og_description || s.description || '');
                setContent('og-image', s.og_image_url || '');

                if (s.favicon_url) setHref('favicon', s.favicon_url);

                if (s.google_tag) {
                    const gid = s.google_tag.trim();
                    const gs1 = document.createElement('script');
                    gs1.async = true; gs1.src = `https://www.googletagmanager.com/gtag/js?id=${gid}`;
                    document.head.appendChild(gs1);
                    const gs2 = document.createElement('script');
                    gs2.textContent = `window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gid}');`;
                    document.head.appendChild(gs2);
                }

                if (s.head_scripts) {
                    const wrapper = document.createElement('div');
                    wrapper.innerHTML = s.head_scripts;
                    while (wrapper.firstChild) {
                        document.head.appendChild(wrapper.firstChild);
                    }
                }

                // WhatsApp & Email (page elements)
                const phone = s.phone || '085805566344';
                const email = s.email || 'hello@webkalcer.com';
                const waMsg = encodeURIComponent(s.wa_message || 'Halo kak, saya tertarik dengan layanan webkalcer.com');

                const waLink = document.getElementById('wa-link');
                if (waLink) waLink.href = `https://wa.me/${phone}?text=${waMsg}`;

                const waFloating = document.getElementById('wa-floating');
                if (waFloating) waFloating.href = `https://wa.me/${phone}?text=${waMsg}`;

                const emailLink = document.getElementById('email-link');
                if (emailLink) emailLink.href = `mailto:${email}`;

                const footerPhone = document.getElementById('footer-phone');
                if (footerPhone) {
                    footerPhone.href = `tel:${phone}`;
                    footerPhone.textContent = phone;
                }

                const footerEmail = document.getElementById('footer-email');
                if (footerEmail) {
                    footerEmail.href = `mailto:${email}`;
                    footerEmail.textContent = email;
                }
            } catch (e) {
                console.warn('SEO settings fetch failed:', e);
            }
        };
    </script>

