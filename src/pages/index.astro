    <!-- Page-specific: load featured package -->
    <script>
        // Load featured package for Harga section
        async function loadHargaPackage() {
            const container = document.getElementById('harga-container');
            if (!container) return;
            try {
                const res = await fetch(`${window.__SUPABASE_URL}/rest/v1/packages?select=*&is_active=eq.true&order=sort_order.asc&limit=1`, {
                    headers: { apikey: window.__SUPABASE_KEY, Authorization: `Bearer ${window.__SUPABASE_KEY}` }
                });
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                const pkgs = await res.json();
                if (!pkgs || pkgs.length === 0) {
                    container.innerHTML = `<p class="t-small" style="text-align:center;color:var(--fg-3);">Belum ada paket tersedia.</p>`;
                    return;
                }
                const p = pkgs[0];
                const features = Array.isArray(p.features) ? p.features : [];
                const hasPromo = p.promo && Number(p.promo) > 0;
                const hasBadge = !!p.badge;
                const eh = window.__escapeHtml;
                const fp = window.__formatPrice;
                container.innerHTML = `
                    <div style="background:var(--bg-2);border:1px solid ${hasBadge ? 'var(--accent)' : 'var(--border)'};${hasBadge ? 'box-shadow:0 0 0 1px var(--accent),0 12px 48px rgba(245,158,11,0.1);' : ''}border-radius:16px;padding:40px;position:relative;overflow:hidden;">
                        ${hasBadge ? `
                        <div style="position:absolute;top:16px;right:-28px;background:var(--accent);color:#0b0b0b;font-size:0.65rem;font-weight:700;letter-spacing:0.08em;padding:4px 40px;transform:rotate(45deg);white-space:nowrap;">${eh(p.badge)}</div>
                        ` : ''}
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                            <span style="font-size:1.4rem;">${p.icon || '📦'}</span>
                            <span class="t-h2">${eh(p.name) || 'Paket'}</span>
                        </div>
                        ${p.tagline ? `<p class="t-small" style="margin-bottom:12px;">${eh(p.tagline)}</p>` : ''}
                        <p class="t-body" style="font-size:0.9rem;margin-bottom:16px;">${eh(p.description) || ''}</p>
                        ${hasPromo ? `
                        <div style="display:flex;align-items:baseline;gap:8px;margin:16px 0 4px;">
                            <div style="font-size:3rem;font-weight:900;color:var(--accent);letter-spacing:-0.03em;line-height:1;">${fp(p.promo)}</div>
                            <span style="font-size:1rem;color:var(--fg-3);text-decoration:line-through;">${fp(p.price)}</span>
                        </div>` : `
                        <div style="font-size:3rem;font-weight:900;color:var(--accent);letter-spacing:-0.03em;line-height:1;margin:16px 0 4px;">${fp(p.price)}</div>`}
                        ${p.price_note ? `<div class="t-small" style="color:var(--fg-3);">${eh(p.price_note)}</div>` : ''}
                        ${features.length > 0 ? `
                        <ul style="display:flex;flex-direction:column;gap:12px;margin-top:24px;margin-bottom:36px;">
                            ${features.map(f => `
                            <li style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:var(--fg-2);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5" style="flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
                                ${eh(f)}
                            </li>`).join('')}
                        </ul>` : ''}
                        ${p.note ? `<p class="t-small" style="margin-top:16px;font-style:italic;text-align:center;">${eh(p.note)}</p>` : ''}
                        <a href="#kontak" class="btn ${hasBadge ? 'btn-solid' : 'btn-ghost'}" style="width:100%;justify-content:center;margin-top:28px;">Pilih Paket Ini</a>
                    </div>
                `;
            } catch (err) {
                console.warn('Harga package fetch failed:', err);
                container.innerHTML = `<p class="t-small" style="text-align:center;color:var(--fg-3);">Gagal memuat harga.</p>`;
            }
        }
        loadHargaPackage();
    </script>

