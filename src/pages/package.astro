---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    seoPage="package"
    activeNav="package"
    pageTitle="🤙 Paket & Harga | Webkalcer"
    pageDesc="Lihat paket pembuatan website dari Webkalcer. Transparan, custom, dan tanpa biaya tersembunyi."
    canonical="https://webkalcer.com/package"
    ogUrl="https://webkalcer.com/package"
>

    <!-- HERO -->
    <section class="section" id="hero" style="display:flex;align-items:center;min-height:60dvh;padding-top:100px;position:relative;overflow:hidden;">
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%, var(--accent-dim) 0%, transparent 60%);" aria-hidden="true"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:0.3;" aria-hidden="true"></div>
        <div class="container" style="position:relative;z-index:1;">
            <div style="max-width:680px;margin:0 auto;text-align:center;">
                <div class="reveal reveal-up">
                    <span class="accent-line" style="margin:0 auto;"></span>
                </div>
                <h1 class="t-display reveal reveal-up d-1" style="margin-top:20px;margin-bottom:24px;">
                    Pilih paket yang<br>
                    <span style="color:var(--accent);">paling cocok</span>
                </h1>
                <p class="t-body reveal reveal-up d-2" style="max-width:500px;margin:0 auto;font-size:1.05rem;">
                    Semua paket include domain gratis 1 tahun, SSL, hosting, dan support 24/7.<br>
                    <span class="punch">No hidden fee, no drama.</span>
                </p>
            </div>
        </div>
    </section>

    <!-- PACKAGES -->
    <section class="section-sm" id="packages" style="padding-top:0;">
        <div class="container">
            <div id="packages-container">
                <div class="loading">
                    <div class="spinner"></div>
                    <div class="t-body">Muat paket...</div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section" id="kontak" style="display:flex;align-items:center;min-height:80dvh;border-top:1px solid var(--border);">
        <div class="container" style="text-align:center;">
            <div class="reveal reveal-up">
                <span class="accent-line" style="margin:0 auto 20px;"></span>
            </div>
            <h2 class="t-display reveal reveal-up d-1" style="margin-bottom:20px;">
                Siap bikin website<br>
                <span style="color:var(--accent);">impian kamu?</span>
            </h2>
            <p class="t-subtitle reveal reveal-up d-2" style="max-width:480px;margin:0 auto 40px;">
                Konsultasi pertama gratis, tanpa komitmen. Ceritain aja kebutuhan kamu - kami bakal kasih solusi, estimasi harga, dan timeline yang realistis.
            </p>
            <div class="reveal reveal-up d-3" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
                <a id="wa-link" href="https://wa.me/6285805566344" target="_blank" rel="noopener noreferrer" class="btn btn-solid">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Hubungi via WhatsApp
                </a>
                <a id="email-link" href="mailto:halo@webkalcer.com" class="btn btn-ghost">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    Kirim Email
                </a>
            </div>
            <p class="t-small reveal reveal-up d-4" style="margin-top:28px;">Respon cepat, biasanya dalam 5 menit</p>
        </div>
    </section>

    <!-- Page-specific: load all packages -->
    <script>
        async function loadPackages() {
            const container = document.getElementById("packages-container")
            if (!container) return

            try {
                const res = await fetch(`${window.__SUPABASE_URL}/rest/v1/packages?select=*&is_active=eq.true&order=sort_order.asc`, {
                    headers: {
                        apikey: window.__SUPABASE_KEY,
                        Authorization: `Bearer ${window.__SUPABASE_KEY}`
                    }
                })

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`)
                }

                const packages = await res.json()

                if (!packages || packages.length === 0) {
                    container.innerHTML = `
                        <div class="error-state">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--fg-3)" stroke-width="1.5">
                                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <p class="t-body">Belum ada paket tersedia. Tambah data di Supabase dulu ya!</p>
                            <p class="t-small" style="margin-top:8px;">Tabel: packages</p>
                        </div>
                    `
                    return
                }

                const count = packages.length
                let gridClass = 'package-grid'
                if (count === 1) gridClass += ' grid-1'
                else if (count === 2) gridClass += ' grid-2'
                else if (count === 3) gridClass += ' grid-3'
                else if (count === 4) gridClass += ' grid-4'

                const eh = window.__escapeHtml;
                const fp = window.__formatPrice;

                container.innerHTML = `
                    <div class="${gridClass}">
                        ${packages.map((pkg) => {
                            const hasBadge = !!pkg.badge
                            const features = Array.isArray(pkg.features) ? pkg.features : []
                            const hasPromo = pkg.promo && Number(pkg.promo) > 0
                            return `
                                <div class="package-card ${hasBadge ? 'featured' : ''}">
                                    ${hasBadge ? `<div class="package-badge">${eh(pkg.badge)}</div>` : ""}
                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                        <span style="font-size:1.4rem;">${pkg.icon || "📦"}</span>
                                        <span class="t-h2">${eh(pkg.name) || "Paket"}</span>
                                    </div>
                                    ${pkg.tagline ? `<p class="t-small" style="margin-bottom:12px;">${eh(pkg.tagline)}</p>` : ""}
                                    <p class="t-body" style="font-size:0.9rem;margin-bottom:16px;">${eh(pkg.description) || ""}</p>
                                    ${hasPromo ? `<div style="display:flex;align-items:baseline;gap:8px;"><div class="price">${fp(pkg.promo)}</div><span style="font-size:1rem;color:var(--fg-3);text-decoration:line-through;">${fp(pkg.price)}</span></div>` : `<div class="price">${fp(pkg.price)}</div>`}
                                    ${pkg.price_note ? `<div class="price-sub">${eh(pkg.price_note)}</div>` : ""}
                                    ${features.length > 0 ? `
                                        <ul>
                                            ${features.map(f => `
                                                <li>
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5">
                                                        <polyline points="20 6 9 17 4 12"/>
                                                    </svg>
                                                    ${eh(f)}
                                                </li>
                                            `).join("")}
                                        </ul>
                                    ` : ""}
                                    ${pkg.note ? `<p class="t-small" style="margin-top:16px;font-style:italic;">${eh(pkg.note)}</p>` : ""}
                                    <a href="/#kontak" class="btn ${hasBadge ? "btn-solid" : "btn-ghost"}">Pilih Paket Ini</a>
                                </div>
                            `
                        }).join("")}
                    </div>
                `
            } catch (err) {
                console.error("Supabase fetch error:", err)
                container.innerHTML = `
                    <div class="error-state">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                        <p class="t-body">Gagal mengambil data paket.</p>
                        <p class="t-small" style="margin-top:8px;color:#ef4444;">${err.message}</p>
                        <button onclick="location.reload()" class="btn btn-ghost" style="margin-top:20px;">Coba Lagi</button>
                    </div>
                `
            }
        }
        loadPackages()
    </script>

</BaseLayout>
